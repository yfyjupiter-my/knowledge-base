# Auth.js core secret — generate with: openssl rand -base64 33
AUTH_SECRET=

# Google OAuth client, from Google Cloud Console
# Authorized redirect URI: <origin>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Access restriction (PRD: IT Google Workspace domain + group allowlist)
# Comma-separated fallback allowlist of individual emails, plus/or a Workspace domain.
AUTH_ALLOWED_GOOGLE_DOMAIN=
AUTH_ALLOWED_EMAILS=

# Supabase (server-only — never exposed to the browser)
SUPABASE_URL=
# SEC-2: use the SECRET / service_role key, NOT the publishable/anon key.
# Dashboard → Project Settings → API keys → create a secret key.
# The kb_* tables have RLS enabled with no anon policies, so only the secret
# key (which bypasses RLS) can read/write them. Keep it out of any NEXT_PUBLIC_* var.
SUPABASE_API_KEY=
