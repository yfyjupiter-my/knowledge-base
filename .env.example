# Auth.js core secret — generate with: openssl rand -base64 33
AUTH_SECRET=

# Google OAuth client, from Google Cloud Console
# Authorized redirect URI: <origin>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Access restriction (PRD: IT Google Workspace domain + group allowlist)
# Comma-separated fallback allowlist of individual emails, plus/or a Workspace domain.
AUTH_ALLOWED_GOOGLE_DOMAIN=
AUTH_ALLOWED_EMAILS=
